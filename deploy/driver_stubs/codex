#!/usr/bin/env python3
"""codex CLI stub — renders @@SCRIPT@@ as `codex exec --json` output.

The real codex reads the prompt on stdin (trailing `-`); so do we.
"""
import json
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import _stublib as s  # noqa: E402


def emit(obj):
    sys.stdout.write(json.dumps(obj) + "\n")
    sys.stdout.flush()


def main() -> int:
    script = s.read_script("stdin")
    s.maybe_sleep(script)
    if s.is_never_done(script):
        s.hang_forever()
    if s.is_malformed(script):
        sys.stdout.write("<<not json>>\n")
        sys.stdout.flush()
        return 1
    s.materialize_files(script, os.getcwd())
    if s.is_error(script):
        emit({"type": "turn.failed", "error": {"message": s.error_message(script)}})
        return 1
    text = s.final_text(script)
    emit({"type": "item.completed",
          "item": {"type": "agent_message", "text": text}})
    tin, tout = s.usage(script)
    emit({"type": "turn.completed",
          "usage": {"input_tokens": tin, "output_tokens": tout}})
    return 0


if __name__ == "__main__":
    sys.exit(main())
