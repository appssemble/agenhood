#!/usr/bin/env python3
"""opencode CLI stub — renders @@SCRIPT@@ as opencode --format json output.

The real opencode is invoked as: opencode run ... -- "<prompt>"; the prompt is
the last positional argv. We read the script from there.
"""
import json
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import _stublib as s  # noqa: E402


def emit(obj):
    sys.stdout.write(json.dumps(obj) + "\n")
    sys.stdout.flush()


def main() -> int:
    script = s.read_script("argv")
    s.maybe_sleep(script)
    if s.is_never_done(script):
        s.hang_forever()
    if s.is_malformed(script):
        sys.stdout.write("<<not json>>\n")
        sys.stdout.flush()
        return 1
    s.materialize_files(script, os.getcwd())
    if s.is_error(script):
        emit({"type": "error",
              "error": {"name": "StubError",
                        "data": {"message": s.error_message(script)}}})
        return 1
    text = s.final_text(script)
    if text:
        emit({"type": "text", "part": {"text": text}})
    tin, tout = s.usage(script)
    emit({"type": "step_finish",
          "part": {"type": "step-finish",
                   "tokens": {"input": tin, "output": tout,
                              "reasoning": 0, "cache": {"read": 0, "write": 0}}}})
    return 0


if __name__ == "__main__":
    sys.exit(main())
