# Paste into Coolify's env UI (mark secrets as such). NEVER commit real values.
# --- Public host (the app FQDN; Coolify terminates TLS for this) ---
PUBLIC_HOST=agent.example.com

# --- Database (external / Coolify-managed Postgres) ---
# Point at your managed Postgres. A plain `postgres://` URL (as Coolify hands out)
# is accepted and normalized to the asyncpg dialect. The control-plane creates its
# database on first boot if missing; connectors derives + creates its own
# "connectors" database from this URL.
DATABASE_URL=postgres://USER:PASSWORD@your-managed-db-host:5432/agentruntime

# --- Control plane ---
# python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
CREDENTIAL_ENCRYPTION_KEY=__base64_32__
# Seeded staff (admin) login — created idempotently on deploy. This is your first
# login; you'll be forced to change the password on first sign-in. Leave both blank
# to skip seeding a staff account.
SEED_STAFF_EMAIL=you@example.com
SEED_STAFF_PASSWORD=__change_me_temp__
SEED_STAFF_NAME=Admin
AGENT_IMAGE_TAG=1.6.0
AGENT_REGISTRY=registry.example.com
# Pull creds (the control plane pulls the private agent image with these).
AGENT_REGISTRY_USERNAME=registry-puller
AGENT_REGISTRY_PASSWORD=__pull_pwd__
# Per-agent caps, tiered by image variant (`full` ships Chromium and needs more
# headroom than `slim`). Size the VM as base + N x the larger of the two.
# Uncomment to override the compose file's defaults (2g/1 CPU for both tiers,
# matching this deploy's behavior before the variant split existed):
# AGENT_MEM_LIMIT_FULL=4g
# AGENT_CPUS_FULL=2
# AGENT_MEM_LIMIT_SLIM=2g
# AGENT_CPUS_SLIM=1
# AGENT_MEM_LIMIT_MIN=256m
# AGENT_MEM_LIMIT_MAX=8g
# AGENT_CPUS_MIN=0.25
# AGENT_CPUS_MAX=4
AGENT_PIDS_LIMIT=512
# Optional: Exa AI API key (https://exa.ai). When set, agents' web_search and
# web_read use Exa as the primary provider; unset = free SearXNG-only mode.
# EXA_API_KEY=
# Max total bytes moved between two workflow steps (default 500 MB).
# WORKFLOW_TRANSFER_MAX_BYTES=524288000
# Image pull policy at provision time: if-not-present (default) | always.
# AGENT_IMAGE_PULL_POLICY=if-not-present
# Pre-pull sweep interval for the default agent image (registry mode only).
# IMAGE_PREPULL_INTERVAL_SECONDS=600
# Control-plane DB pool sizing.
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# --- Connectors ---
CONNECTORS_MASTER_KEY=__base64_32__
CONNECTORS_PUBLIC_BASE_URL=https://agent.example.com/v1
CONNECTORS_CONSOLE_REDIRECT_URL=https://agent.example.com/settings/connectors
# S2S guard + signed-state connect (shared with the control plane).
CONNECTORS_S2S_TOKEN=__token__
CONNECTORS_STATE_SECRET=__token__
# Provider creds (blank disables that connector).
SLACK_SIGNING_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_OAUTH_SCOPES=app_mentions:read,chat:write
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_SLUG=

# --- Egress proxy / SearXNG ---
EGRESS_DENYLIST=
# Optional: chain agent egress through a rotating proxy (e.g. Webshare).
# Blank => direct. Set at most ONE of EXCLUDE (blacklist) / INCLUDE (whitelist).
# EGRESS_UPSTREAM_PROXY=http://user-rotate:pass@p.webshare.io:80
# EGRESS_UPSTREAM_EXCLUDE=api.anthropic.com,api.openai.com
# EGRESS_UPSTREAM_INCLUDE=
# Fall back to a direct dial if the upstream is down (leaks VM IP). Off by default.
# EGRESS_UPSTREAM_FALLBACK_DIRECT=true
# python -c "import secrets;print(secrets.token_hex(32))"
SEARXNG_SECRET=__hex__
