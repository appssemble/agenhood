# deploy/.env.dev — DEV ONLY. Insecure, committed on purpose. Never use in production.

# --- Database (single canonical connection URL) ---
DATABASE_URL=postgresql+asyncpg://agentruntime:devpassword@postgres:5432/agentruntime

# --- Control plane ---
CREDENTIAL_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
ADMIN_API_KEY=ak_dev_localonly
AGENT_IMAGE_TAG=1.8.0
SEED_TENANT_ID=ten_seed
SEED_API_KEY=tk_live_seedkey
# Optional: Exa AI API key (https://exa.ai) for agents' web_search/web_read; unset = free SearXNG-only mode.
# EXA_API_KEY=

# --- Connectors ---
CONNECTORS_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
CONNECTORS_PUBLIC_BASE_URL=http://localhost:8090
# Provider secrets — leave blank in dev unless testing a specific connector.
SLACK_SIGNING_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# --- Egress proxy / SearXNG / Traefik (unused in dev but referenced by base compose) ---
EGRESS_DENYLIST=
# Upstream rotating proxy is off in dev — agents dial out directly.
EGRESS_UPSTREAM_PROXY=
EGRESS_UPSTREAM_EXCLUDE=
EGRESS_UPSTREAM_INCLUDE=
EGRESS_UPSTREAM_FALLBACK_DIRECT=
SEARXNG_SECRET=devsearxngsecret
PUBLIC_HOST=localhost

# --- Dev console + bootstrap ---
# Must be a real TLD — EmailStr rejects reserved domains like .local.
DEV_ADMIN_EMAIL=admin@example.com
DEV_ADMIN_PASSWORD=devpassword123
# No spaces: bootstrap-dev.sh sources this file with `. "$ENV_FILE"`.
DEV_TENANT_NAME=DevTenant
DEV_CONSOLE_PORT=5173
# Vite (inside web-console-dev) proxies /v1 and /admin to the control-plane service.
VITE_PROXY_TARGET=http://control-plane:8443
