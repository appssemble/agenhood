# Copy to deploy/.env and fill in. NEVER commit deploy/.env.
# --- Database (single canonical connection URL) ---
# The one DB secret for the whole stack. host = the compose service name "postgres".
# Bundled Postgres parses user/password/db from this; connectors derives its own
# "connectors" database URL from it. Password must not contain '@' or ':'.
DATABASE_URL=postgresql+asyncpg://agentruntime:change-me-strong-password@postgres:5432/agentruntime

# --- Control plane ---
# AES-GCM master key for tenant LLM-credential encryption (spec §4.5, §8.5).
# Generate: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
CREDENTIAL_ENCRYPTION_KEY=base64-32-byte-key-goes-here
# ChatGPT subscription auth (OpenAI device-flow OAuth). Optional; the API-key
# path keeps working if these are unset. Set the kill switch to disable globally.
OAUTH_SUBSCRIPTION_KILL_SWITCH=false
OAUTH_SUBSCRIPTION_GRACE_SECONDS=300
OAUTH_POLL_SWEEP_INTERVAL_SECONDS=5
OAUTH_POLL_MAX_INTERVAL_SECONDS=120
OAUTH_CONNECTION_SWEEP_INTERVAL_SECONDS=3600
# Unofficial Codex OAuth surface — patch here if OpenAI changes it (spec §9).
OPENAI_OAUTH_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
OPENAI_OAUTH_SCOPES="openid profile email offline_access"
OPENAI_OAUTH_DEVICE_CODE_URL=https://auth.openai.com/api/accounts/deviceauth/usercode
OPENAI_OAUTH_TOKEN_URL=https://auth.openai.com/api/accounts/deviceauth/token
OPENAI_OAUTH_REFRESH_URL=https://auth.openai.com/oauth/token
# Claude Code subscription (Anthropic claude.ai OAuth — reverse-engineered, overridable).
# Defaults track the current undocumented endpoints; change if Anthropic migrates hosts.
# ANTHROPIC_OAUTH_CLIENT_ID=9d1c250a-e61b-44d9-88ed-5944d1962f5e
# ANTHROPIC_OAUTH_AUTHORIZE_URL=https://claude.ai/oauth/authorize
# ANTHROPIC_OAUTH_TOKEN_URL=https://console.anthropic.com/v1/oauth/token
# ANTHROPIC_OAUTH_REDIRECT_URI=https://console.anthropic.com/oauth/code/callback
# ANTHROPIC_OAUTH_SCOPES=user:inference user:profile
# Break-glass admin key (spec §4.3). Generate: python -c "import secrets;print('ak_'+secrets.token_urlsafe(32))"
ADMIN_API_KEY=ak_change-me
# Image tag the control plane provisions agents from (spec §4.7). Must match a
# published tag exactly, e.g. ghcr.io/appssemble/agent-runtime:1.1.0 (no "v" prefix).
AGENT_IMAGE_TAG=1.1.0
# Max total bytes moved between two workflow steps (default 500 MB).
# WORKFLOW_TRANSFER_MAX_BYTES=524288000
# Image pull policy at provision time: if-not-present (default) | always.
# AGENT_IMAGE_PULL_POLICY=if-not-present
# Pre-pull sweep interval for the default agent image (registry mode only).
# IMAGE_PREPULL_INTERVAL_SECONDS=600
# Control-plane DB pool sizing.
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# --- Connectors ---
# AES-GCM master key for connector credential encryption.
# Generate: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
CONNECTORS_MASTER_KEY=base64-32-byte-key-goes-here
# Public base URL for OAuth redirect URIs (must be reachable by provider).
CONNECTORS_PUBLIC_BASE_URL=https://agent.example.com/connectors
# Slack app credentials (leave blank to disable Slack connector).
SLACK_SIGNING_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# GitHub App credentials (leave blank to disable GitHub connector).
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# --- Egress proxy ---
# Comma-separated hostnames to block in addition to RFC1918/link-local (spec §8.1).
EGRESS_DENYLIST=

# Route agent egress through a rotating proxy service (e.g. Webshare) so requests
# present rotating exit IPs. Leave blank to connect directly (the default).
# Format: http://[user:pass@]host[:port] — percent-encode reserved chars in the password.
# Webshare note: use the host:port from your dashboard's proxy list. Rotation is
# controlled by the USERNAME, not the host: a plain username is sticky (one exit IP),
# while appending "-rotate" (e.g. myuser-rotate) gives a new IP per request. The
# shared p.webshare.io gateway is not reachable on all plans — prefer the dashboard
# endpoint. Example rotating: http://myuser-rotate:pass@p-host.webshare.io:PORT
EGRESS_UPSTREAM_PROXY=
# Choose ONE of the two lists below (setting both refuses to start). Entries are
# comma-separated and match subdomains: "example.com" also covers "api.example.com".
# Blacklist — these hosts go direct, everything else goes through the upstream.
# Worth excluding the LLM APIs: they are the bulk of the bytes (billed per GB by the
# proxy service) and providers may rate-limit or block rotating exit IPs.
EGRESS_UPSTREAM_EXCLUDE=
# Whitelist — ONLY these hosts go through the upstream, everything else goes direct.
EGRESS_UPSTREAM_INCLUDE=
# If the upstream proxy is unreachable, fall back to a DIRECT connection instead of
# failing the request. Off by default — a fallback leaks this VM's real IP, so the
# default fails closed (502). Set to "true" only if availability matters more than
# guaranteeing every request exits through the proxy.
EGRESS_UPSTREAM_FALLBACK_DIRECT=

# --- SearXNG ---
# Generate: python -c "import secrets;print(secrets.token_hex(32))"
SEARXNG_SECRET=change-me-searxng-secret

# --- Traefik / public host ---
PUBLIC_HOST=agent.example.com
